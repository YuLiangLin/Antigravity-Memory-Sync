{
    "name": "antigravity-explorer",
    "displayName": "%extension.displayName%",
    "description": "%extension.description%",
    "version": "0.4.0",
    "publisher": "NathanLin",
    "icon": "media/icon.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other",
        "Visualization"
    ],
    "keywords": [
        "antigravity",
        "gemini",
        "ai",
        "skills",
        "memory",
        "sync"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "l10n": "./l10n",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "antigravity-explorer",
                    "title": "%viewsContainer.title%",
                    "icon": "media/icon.svg"
                }
            ]
        },
        "views": {
            "antigravity-explorer": [
                {
                    "id": "antigravity-skills",
                    "name": "%view.skills%"
                },
                {
                    "id": "antigravity-brain",
                    "name": "%view.brain%"
                },
                {
                    "id": "antigravity-sync",
                    "name": "%view.sync%"
                }
            ]
        },
        "commands": [
            {
                "command": "antigravity.openDashboard",
                "title": "%command.openDashboard%",
                "icon": "$(dashboard)"
            },
            {
                "command": "antigravity.syncMemory",
                "title": "%command.syncMemory%",
                "icon": "$(sync)"
            },
            {
                "command": "antigravity.exportMemory",
                "title": "%command.exportMemory%",
                "icon": "$(cloud-upload)"
            },
            {
                "command": "antigravity.importMemory",
                "title": "%command.importMemory%",
                "icon": "$(cloud-download)"
            },
            {
                "command": "antigravity.openBrainDashboard",
                "title": "%command.openBrainDashboard%",
                "icon": "$(graph)"
            },
            {
                "command": "antigravity.distillBrain",
                "title": "%command.distillBrain%",
                "icon": "$(beaker)"
            },
            {
                "command": "antigravity.refresh",
                "title": "%command.refresh%",
                "icon": "$(refresh)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "antigravity.refresh",
                    "when": "view =~ /^antigravity-/",
                    "group": "navigation"
                },
                {
                    "command": "antigravity.openDashboard",
                    "when": "view == antigravity-skills",
                    "group": "navigation"
                },
                {
                    "command": "antigravity.openBrainDashboard",
                    "when": "view == antigravity-brain",
                    "group": "navigation"
                },
                {
                    "command": "antigravity.distillBrain",
                    "when": "view == antigravity-brain",
                    "group": "navigation"
                }
            ]
        },
        "configuration": {
            "title": "Antigravity Explorer",
            "properties": {
                "antigravity.geminiApiKey": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "%config.geminiApiKey%"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts",
        "package": "npx @vscode/vsce package"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/vscode": "^1.85.0",
        "@vscode/vsce": "^2.22.0",
        "typescript": "^5.3.0"
    },
    "dependencies": {
        "gray-matter": "^4.0.3"
    }
}