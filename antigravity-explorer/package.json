{
    "name": "antigravity-explorer",
    "displayName": "%extension.displayName%",
    "description": "%extension.description%",
    "version": "0.17.5",
    "publisher": "NathanLin",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/YuLiangLin/Antigravity-Memory-Sync"
    },
    "icon": "media/icon.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other",
        "Visualization"
    ],
    "keywords": [
        "antigravity",
        "gemini",
        "ai",
        "skills",
        "memory",
        "sync"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "l10n": "./l10n",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "antigravity-explorer",
                    "title": "%viewsContainer.title%",
                    "icon": "media/icon.svg"
                }
            ]
        },
        "views": {
            "antigravity-explorer": [
                {
                    "id": "antigravity-skills",
                    "name": "%view.skills%"
                },
                {
                    "id": "antigravity-brain",
                    "name": "%view.brain%"
                },
                {
                    "id": "antigravity-sync",
                    "name": "%view.sync%"
                },
                {
                    "id": "antigravity-projects",
                    "name": "Projects"
                },
                {
                    "id": "antigravity-agents",
                    "name": "%view.agents%"
                }
            ]
        },
        "commands": [
            {
                "command": "antigravity.openDashboard",
                "title": "%command.openDashboard%",
                "icon": "$(dashboard)"
            },
            {
                "command": "antigravity.syncMemory",
                "title": "%command.syncMemory%",
                "icon": "$(sync)"
            },
            {
                "command": "antigravity.exportMemory",
                "title": "%command.exportMemory%",
                "icon": "$(cloud-upload)"
            },
            {
                "command": "antigravity.importMemory",
                "title": "%command.importMemory%",
                "icon": "$(cloud-download)"
            },
            {
                "command": "antigravity.openBrainDashboard",
                "title": "%command.openBrainDashboard%",
                "icon": "$(graph)"
            },
            {
                "command": "antigravity.distillBrain",
                "title": "%command.distillBrain%",
                "icon": "$(beaker)"
            },
            {
                "command": "antigravity.openAgentOffice",
                "title": "%command.openAgentOffice%",
                "icon": "$(organization)"
            },
            {
                "command": "antigravity.generateAgent",
                "title": "%command.generateAgent%",
                "icon": "$(sparkle)"
            },
            {
                "command": "antigravity.setupSync",
                "title": "Antigravity: Setup Sync",
                "icon": "$(gear)"
            },
            {
                "command": "antigravity.scanProjects",
                "title": "Antigravity: Scan Projects",
                "icon": "$(search)"
            },
            {
                "command": "antigravity.setGitLabToken",
                "title": "Antigravity: Set GitLab Token",
                "icon": "$(key)"
            },
            {
                "command": "antigravity.discoverGitLabProjects",
                "title": "Antigravity: Discover GitLab Projects",
                "icon": "$(cloud)"
            },
            {
                "command": "antigravity.cloneProject",
                "title": "Antigravity: Clone Project",
                "icon": "$(cloud-download)"
            },
            {
                "command": "antigravity.pullAllRepos",
                "title": "Antigravity: Pull All Repos",
                "icon": "$(repo-pull)"
            },
            {
                "command": "antigravity.refresh",
                "title": "%command.refresh%",
                "icon": "$(refresh)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "antigravity.refresh",
                    "when": "view =~ /^antigravity-/",
                    "group": "navigation"
                },
                {
                    "command": "antigravity.openDashboard",
                    "when": "view == antigravity-skills",
                    "group": "navigation"
                },
                {
                    "command": "antigravity.openBrainDashboard",
                    "when": "view == antigravity-brain",
                    "group": "navigation"
                },
                {
                    "command": "antigravity.distillBrain",
                    "when": "view == antigravity-brain",
                    "group": "navigation"
                },
                {
                    "command": "antigravity.scanProjects",
                    "when": "view == antigravity-projects",
                    "group": "navigation"
                },
                {
                    "command": "antigravity.discoverGitLabProjects",
                    "when": "view == antigravity-projects",
                    "group": "navigation"
                },
                {
                    "command": "antigravity.pullAllRepos",
                    "when": "view == antigravity-projects || view == antigravity-sync",
                    "group": "navigation"
                },
                {
                    "command": "antigravity.setGitLabToken",
                    "when": "view == antigravity-projects",
                    "group": "2_settings"
                }
            ]
        },
        "configuration": {
            "title": "Antigravity Explorer",
            "properties": {
                "antigravity.geminiApiKey": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "%config.geminiApiKey%"
                },
                "antigravity.autoSync": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "%config.autoSync%"
                },
                "antigravity.autoSyncInterval": {
                    "type": "number",
                    "default": 30,
                    "minimum": 5,
                    "maximum": 1440,
                    "markdownDescription": "%config.autoSyncInterval%"
                },
                "antigravity.autoDistill": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "%config.autoDistill%"
                },
                "antigravity.autoDistillThreshold": {
                    "type": "number",
                    "default": 5,
                    "minimum": 1,
                    "maximum": 50,
                    "markdownDescription": "%config.autoDistillThreshold%"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts",
        "package": "npx @vscode/vsce package"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/vscode": "^1.85.0",
        "@vscode/vsce": "^2.22.0",
        "typescript": "^5.3.0"
    },
    "dependencies": {
        "gray-matter": "^4.0.3"
    }
}